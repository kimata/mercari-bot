{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "profile": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "user": {
                        "type": "string"
                    },
                    "pass": {
                        "type": "string"
                    },
                    "discount": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "favorite_count": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "step": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "threshold": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "favorite_count",
                                "step",
                                "threshold"
                            ]
                        }
                    },
                    "line": {
                        "type": "object",
                        "properties": {
                            "user": {
                                "type": "string"
                            },
                            "pass": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "pass",
                            "user"
                        ]
                    },
                    "interval": {
                        "type": "object",
                        "properties": {
                            "hour": {
                                "type": "integer",
                                "minimum": 1
                            }
                        },
                        "required": [
                            "hour"
                        ]
                    }
                },
                "required": [
                    "discount",
                    "interval",
                    "line",
                    "name",
                    "pass",
                    "user"
                ]
            }
        },
        "data": {
            "type": "object",
            "properties": {
                "selenium": {
                    "type": "string"
                },
                "dump": {
                    "type": "string"
                },
                "history": {
                    "type": "string"
                }
            },
            "required": [
                "dump",
                "selenium"
            ]
        },
        "slack": {
            "type": "object",
            "properties": {
                "bot_token": {
                    "type": "string"
                },
                "from": {
                    "type": "string"
                },
                "info": {
                    "type": "object",
                    "properties": {
                        "channel": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "name"
                            ]
                        }
                    },
                    "required": [
                        "channel"
                    ]
                },
                "captcha": {
                    "type": "object",
                    "properties": {
                        "channel": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "id": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "id",
                                "name"
                            ]
                        }
                    },
                    "required": [
                        "channel"
                    ]
                },
                "error": {
                    "type": "object",
                    "properties": {
                        "channel": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "id": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "id",
                                "name"
                            ]
                        },
                        "interval_min": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "channel",
                        "interval_min"
                    ]
                }
            },
            "required": [
                "bot_token",
                "captcha",
                "error",
                "from",
                "info"
            ]
        },
        "mail": {
            "type": "object",
            "properties": {
                "smtp": {
                    "type": "object",
                    "properties": {
                        "host": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer"
                        }
                    },
                    "required": [
                        "host",
                        "port"
                    ]
                },
                "user": {
                    "type": "string"
                },
                "pass": {
                    "type": "string"
                },
                "from": {
                    "type": "string"
                },
                "to": {
                    "type": "string"
                }
            },
            "required": [
                "from",
                "pass",
                "smtp",
                "to",
                "user"
            ]
        }
    },
    "required": [
        "data",
        "profile"
    ]
}
